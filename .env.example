# =============================================================================
# Lou Lou's + Foster's — Drink Ordering App
# Copy this file to ".env.local" for local development, and set the same
# variables in your Vercel project settings for production.
#
#   cp .env.example .env.local
#
# NEVER commit .env.local or real secret values to git.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. SUPABASE  (Project Settings -> API in the Supabase dashboard)
# -----------------------------------------------------------------------------
# The project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# The "anon" / publishable key. Safe to expose to the browser. Protected by RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# The "service_role" / secret key. FULL ADMIN ACCESS — SERVER ONLY.
# Never prefix this with NEXT_PUBLIC_. Never import it into a client component.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# 2. TWILIO  (https://console.twilio.com)
# -----------------------------------------------------------------------------
# Account SID (starts with "AC...")
TWILIO_ACCOUNT_SID=

# Auth token (secret)
TWILIO_AUTH_TOKEN=

# The Twilio phone number that sends the SMS, in E.164 format, e.g. +17065551234
TWILIO_FROM_NUMBER=

# -----------------------------------------------------------------------------
# 3. APP CONFIG
# -----------------------------------------------------------------------------
# The public base URL of the deployed app. Used to build the QR code target and
# absolute links. In local dev this is http://localhost:3000. In production set
# it to your real domain, e.g. https://order.loulousfosters.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# The slug of the "default" restaurant used by the root customer URL and QR code.
# Matches the "slug" column of the restaurants table (see supabase/seed.sql).
NEXT_PUBLIC_DEFAULT_RESTAURANT_SLUG=lou-lous-fosters

# -----------------------------------------------------------------------------
# 4. MENU EXTRACTION (optional for MVP — a mock is used when unset)
# -----------------------------------------------------------------------------
# Provider for turning an uploaded menu file into structured drinks.
# Leave BLANK to use the built-in MOCK extractor (recommended for first launch).
# Set to "anthropic" or "openai" to enable live extraction (see lib/extraction).
MENU_EXTRACTION_PROVIDER=

# API key for the chosen extraction provider. SERVER ONLY.
MENU_EXTRACTION_API_KEY=

# -----------------------------------------------------------------------------
# 5. SECURITY
# -----------------------------------------------------------------------------
# A random secret used to sign the customer anti-duplicate / idempotency cookie.
# Generate one with:  openssl rand -hex 32
ORDER_SIGNING_SECRET=
